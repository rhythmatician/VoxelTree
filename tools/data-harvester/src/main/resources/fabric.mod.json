{
    "schemaVersion": 1,
    "id": "dataharvester",
    "version": "${version}",
    "name": "Data Harvester",
    "description": "Auto-connect bot for automated Voxy data extraction. Connects to a configured server on launch and stays idle while VoxyWorldGen populates the Voxy LOD database.",
    "authors": [
        "VoxelTree"
    ],
    "license": "MIT",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.voxeltree.harvester.DataHarvesterMod"
        ],
        "client": [
            "com.voxeltree.harvester.DataHarvesterClient"
        ]
    },
    "mixins": [
        "dataharvester.mixins.json"
    ],
    "accessWidener": "data-harvester.accesswidener",
    "depends": {
        "fabricloader": ">=0.16.0",
        "minecraft": ">=1.21.6 <=1.21.11",
        "java": ">=21",
        "fabric-api": "*"
    }
}